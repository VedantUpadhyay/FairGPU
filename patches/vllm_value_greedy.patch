+class ValueGreedyRequestQueue(RequestQueue):
+    """
+    Schedules requests in descending order of instantaneous value decay rate.
+    Higher decay rate = more urgent = served first.
+    """
+
+    def __init__(self) -> None:
+        self._queue: list[Request] = []
+
+    def _sort(self) -> None:
+        """Sort requests by descending instantaneous value decay rate."""
+        self._queue.sort(
+            key=lambda r: value_greedy_key(r, _time.time()),
+            reverse=True,
+        )
+
+    def add_request(self, request: Request) -> None:
+        """Add a request to the queue according to value-greedy policy."""
+        self._queue.append(request)
+        self._sort()
+
+    def pop_request(self) -> Request:
+        """Pop a request from the queue according to value-greedy policy."""
+        if not self._queue:
+            raise IndexError("pop from empty ValueGreedyQueue")
+        self._sort()
+        return self._queue.pop(0)
+
+    def peek_request(self) -> Request:
+        """Peek at the next request in the queue without removing it."""
+        if not self._queue:
+            raise IndexError("peek from empty ValueGreedyQueue")
+        self._sort()
+        return self._queue[0]
+
+    def prepend_request(self, request: Request) -> None:
+        """Add a request to the queue according to value-greedy policy."""
+        self.add_request(request)
+
+    def prepend_requests(self, requests: RequestQueue) -> None:
+        """Add all requests from another queue according to value-greedy policy."""
+        for request in requests:
+            self._queue.append(request)
+        self._sort()
+
+    def remove_request(self, request: Request) -> None:
+        """Remove a specific request from the queue."""
+        self._queue.remove(request)
+
+    def remove_requests(self, requests: Iterable[Request]) -> None:
+        """Remove multiple specific requests from the queue."""
+        requests_to_remove = requests if isinstance(requests, set) else set(requests)
+        self._queue = [r for r in self._queue if r not in requests_to_remove]
+
+    def add(self, request: Request) -> None:
+        """Add a request to the queue according to value-greedy policy."""
+        self.add_request(request)
+
+    def pop(self) -> Request:
+        """Pop a request from the queue according to value-greedy policy."""
+        return self.pop_request()
+
+    def peek(self) -> Request | None:
+        """Peek at the next request in the queue without removing it."""
+        if not self._queue:
+            return None
+        return self.peek_request()
+
+    def __len__(self) -> int:
+        """Get number of requests in queue."""
+        return len(self._queue)
+
+    def __iter__(self) -> Iterator[Request]:
+        """Iterate over the queue according to value-greedy policy."""
+        self._sort()
+        return iter(self._queue)
+
+    def __bool__(self) -> bool:
+        """Check if queue has any requests."""
+        return len(self._queue) > 0
+
+
